    "N_2 = 10000\n",
    "n_bins_2 = 100\n",
    "p_2 = 1 / n_bins_2\n",
    "\n",
    "conteggi_2 = []\n",
    "\n",
    "# Ripeto la simulazione M volte\n",
    "for i in range(M):\n",
    "    dati_temporanei = np.random.uniform(0, 1, N_2)\n",
    "    conteggi_temp, _ = np.histogram(dati_temporanei, bins=n_bins_2, range=(0, 1))\n",
    "    conteggi_2.append(conteggi_temp[50])\n",
