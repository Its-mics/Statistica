    "\n",
    "# 7. Sovrapponiamo la Normale Standard teorica\n",
    "x = np.linspace(-4, 4, 100)\n",
    "y_teorica = m * bin_width * norm.pdf(x, 0, 1) # m * ampiezza_bin * densità_normale\n",
